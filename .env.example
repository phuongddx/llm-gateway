LLM_PROVIDER=gemini
LLM_API_KEY=your-api-key-here
LLM_MODEL=gemini-2.0-flash-lite

# Gateway auth — REQUIRED, must be set before starting
APP_API_KEY=

# Per-provider API keys (optional — falls back to LLM_API_KEY)
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
BYTEDANCE_API_KEY=
GLM_API_KEY=

# CORS — comma-separated allowed origins (empty = no CORS headers)
CORS_ORIGINS=

# Rate limiting (per client IP)
RATE_LIMIT=60/minute

# Analytics database path
ANALYTICS_DB_PATH=data/analytics.db

# LLM_BASE_URL=
